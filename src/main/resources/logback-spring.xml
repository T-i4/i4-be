<configuration>
  <!-- 콘솔 로그 설정 -->
  <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 파일 로그 설정 -->
  <appender name="file" class="ch.qos.logback.core.FileAppender">
    <file>logs/application.log</file> <!-- 로그 파일 위치 -->
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 로그 레벨 설정 (전체 로그 레벨을 INFO로 설정) -->
  <logger name="com.business" level="INFO" additivity="false">
    <appender-ref ref="file"/>
    <appender-ref ref="console"/>
  </logger>

  <!-- 루트 로그 설정 (전체 시스템 로그 레벨을 INFO로 설정) -->
  <root level="INFO">
    <appender-ref ref="console"/>
    <appender-ref ref="file"/>
  </root>
</configuration>